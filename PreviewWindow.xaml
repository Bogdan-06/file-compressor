<Window x:Class="FileCompressorModern.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preview Comparison"
        Width="1120"
        Height="680"
        MinWidth="900"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#18202F"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#697586"/>
        <SolidColorBrush x:Key="LineBrush" Color="#DEE5EF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#167E71"/>

        <Style x:Key="Panel" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="ButtonBase" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Preview Comparison" Foreground="{StaticResource InkBrush}" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="Play the original and compressed videos side by side. If a preview is blank, Windows may not have the codec needed for inline playback."
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,6,0,14"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Panel}">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Original" Foreground="{StaticResource InkBrush}" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="OriginalPathText" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#0F1722" CornerRadius="8">
                        <MediaElement x:Name="OriginalPlayer"
                                      LoadedBehavior="Manual"
                                      UnloadedBehavior="Manual"
                                      Stretch="Uniform"
                                      MediaFailed="MediaElement_MediaFailed"/>
                    </Border>

                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Panel}">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Compressed" Foreground="{StaticResource InkBrush}" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CompressedPathText" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#0F1722" CornerRadius="8">
                        <MediaElement x:Name="CompressedPlayer"
                                      LoadedBehavior="Manual"
                                      UnloadedBehavior="Manual"
                                      Stretch="Uniform"
                                      MediaFailed="MediaElement_MediaFailed"/>
                    </Border>

                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <TextBlock x:Name="MessageText" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Play Both" Style="{StaticResource PrimaryButton}" Width="104" Click="PlayBoth_Click"/>
                <Button Content="Pause Both" Style="{StaticResource ButtonBase}" Width="104" Margin="8,0,0,0" Click="PauseBoth_Click"/>
                <Button Content="Restart Both" Style="{StaticResource ButtonBase}" Width="112" Margin="8,0,0,0" Click="RestartBoth_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Open Original" Style="{StaticResource ButtonBase}" Width="112" Click="OpenOriginal_Click"/>
                <Button Content="Open Compressed" Style="{StaticResource ButtonBase}" Width="128" Margin="8,0,0,0" Click="OpenCompressed_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
